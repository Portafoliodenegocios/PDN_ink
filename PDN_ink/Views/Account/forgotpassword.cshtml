@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>PDN INK - Recuperar Contraseña</title>
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <link rel="stylesheet" href="~/css/login.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
</head>
<body>
    <!-- Fondo Animado -->
    <i class="bg-overlay"></i>
    <canvas id="spiders"></canvas>

    <div class="login-container">
        <!-- Columna del Formulario -->
        <div class="login-form-column">
            <div class="login-content">
                <div class="logo-container">
                    <img src="~/img/icono.png" alt="Logo PDNInk">
                </div>

                <h1>RECUPERAR CONTRASEÑA</h1>
                <p class="subtitle">Ingrese su correo electrónico para recibir instrucciones</p>

            @*     <form onsubmit="event.preventDefault(); alert('Se ha enviado un correo de recuperación.'); window.location.href='login.html'"> *@
                    <div class="form-group">
                        <label for="email">Correo Electrónico</label>
                        <div class="input-wrapper">
                            <i class="fa-solid fa-envelope input-icon"></i>
                            <input type="email" id="email" placeholder="ejemplo@correo.com" required>
                        </div>
                    </div>

                    <button type="submit" id="btn_send" class="btn-login">Enviar</button>
             @*    </form> *@

                <div class="forgot-password">
                    <a asp-controller="Account" asp-action="login">
                    <i class="fa-solid fa-arrow-left"></i> Volver al inicio de sesión</a>
                   
                </div>
            </div>
        </div>

        <!-- Columna de la Imagen -->
        <div class="login-image-column">
            <div class="image-overlay">
                <h2>Gestión de documentos y firma electrónica</h2>
            </div>
            <img src="~/img/login.jpg" alt="Fondo Login">
        </div>
    </div>

    <!-- Script de Animación -->
    <script src="~/js/login-animation.js"></script>


    <script type="text/javascript">
     
        const loginUrl = '@Url.Action("Login", "Account")';

        $('#btn_send').on('click', function (e) {
              e.preventDefault();
        const $btn = $(this);
        const emailValue = $("#email").val().trim();
        if (!emailValue) {
                Swal.fire({
                     icon: 'warning',
                     title: 'Campo requerido',
                     text: 'Por favor, ingrese su correo electrónico.'
                }).then(() => {
                     $("#email").focus();
                });
        return;
        }
        $btn.prop("disabled", true);
        $.ajax({
        url: "/Account/ExistEmail",
            type: "POST",
            data: { email: emailValue }
        })
        .done(function (response) {
    
        const exists = (response === true || response.exists === true);

        if (exists) {

            $.ajax({
                url: "/Account/ForgotPassword",
                type: "POST",
                data: { email: emailValue }
            })
            .done(function () {
                Swal.fire({
                    icon: 'success',
                    title: 'Correo verificado',
                    text: 'Se han enviado las instrucciones de recuperación a su cuenta.',
                    confirmButtonText: 'Ir al Login'
            }).then(() => {
            window.location.href = loginUrl;
            });
            })
            .fail(function () {
                Swal.fire({
                    icon: 'error',
                    title: 'Error',
                    text: 'No se pudo procesar la recuperación de contraseña.'
                });
               $btn.prop("disabled", false);
            });
              
        }
        else 
        {
         Swal.fire({
              icon: 'error',
              title: 'Usuario no encontrado',
              text: 'El correo ingresado no pertenece a ninguna cuenta activa.'
            });
        $btn.prop("disabled", false);
        }
        })
        .fail(function () {
            Swal.fire({
                icon: 'error',
                title: 'Error de conexión',
                text: 'No se pudo contactar con el servidor. Intente más tarde.'
           });
        $btn.prop("disabled", false);
        })
        .always(function () {
        if (typeof hideLoading === 'function') hideLoading();
        });
        });
    </script>

  

</body>
</html>