@using Microsoft.Extensions.Configuration
@inject IConfiguration Configuration
@{
    ViewData["Title"] = "Home Page";
    Layout = "_Layout";
    string token = ViewData["TokenRH"] as string;

}
<!DOCTYPE html>
<html lang="es">
 <head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Documentos - PDNInk</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/sweetalert2@11/dist/sweetalert2.min.css">
    <link rel="stylesheet" href="~/css/index.css">
    <link rel="stylesheet" href="~/css/dashboard.css">   
</head>

<body>
    <div class="dashboard-container">
        <!-- Sidebar -->
        <aside class="sidebar" id="sidebar">

            <button class="close-sidebar-btn" id="closeSidebarBtn">
                <i class="fa-solid fa-chevron-left"></i>
            </button>
            <div class="sidebar-header">
                <img src="~/img/icono.png" class="logo-img" alt="Logo">
            </div>

            <nav class="sidebar-nav">

                <ul>
                    <li class="active" onclick="DashboardApp.Navigation.loadPage('originacion', this)">
                        <a href="#" title="Documentos originación del crédito"><i class="fa-solid fa-file-contract icon"></i><span class="menu-text">Documentos originación del crédito</span></a>
                    </li>
                    <li onclick="DashboardApp.Navigation.loadPage('generales', this)">
                        <a href="#" title="Documentos Generales"><i class="fa-solid fa-folder-open icon"></i><span class="menu-text">Documentos Generales</span></a>
                    </li>
                    <li onclick="DashboardApp.Navigation.loadPage('vistos', this)">
                        <a href="#" title="Documentos vistos"><i class="fa-solid fa-eye icon"></i><span class="menu-text">Documentos vistos</span></a>
                    </li>
                    <li onclick="DashboardApp.Navigation.loadPage('carpetas', this)">
                        <a href="#" title="Mis Carpetas"><i class="fa-solid fa-folder icon"></i><span class="menu-text">Mis Carpetas</span></a>
                    </li>
                    <li onclick="DashboardApp.Navigation.loadPage('dashboard', this)">
                        <a href="#" title="Dashboard"><i class="fa-solid fa-chart-line icon"></i><span class="menu-text">Dashboard</span></a>
                    </li>
                    <li onclick="DashboardApp.Navigation.loadPage('configuracion', this)">
                        <a href="#" title="Ajustes"><i class="fa-solid fa-gear icon"></i><span class="menu-text">Ajustes</span></a>
                    </li>
                    <li>
                        @if (ViewData["TokenRH"] != null)
                        {
                            <a href="@Configuration["SiteRH:RH"]Formatos?access_token=@ViewData["TokenRH"]">
                                <i class="fa-regular fa-file-excel"></i>
                                <span class="menu-text"> Capital Humano</span>
                            </a>
                        }
                        else
                        {
                            <a href="/Account/Login">
                                <i class="fa-regular fa-file-excel"></i>
                                <span class="menu-text">Sesión expirada</span>
                            </a>
                        }
                    </li>
                    <li>
                      <a href="@Url.Action("Login", "Account")" title="Salir">
                        <i class="fa-solid fa-right-from-bracket icon"></i>
                        <span class="menu-text">Salir</span>
                      </a>

                </ul>
                            
             </nav>
        </aside>  

