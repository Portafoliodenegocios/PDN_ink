                </div>
            </div>
        </main>

    </div>


    <!-- MODAL DE FIRMA -->
    <div id="signModal" class="modal-overlay">
        <div class="modal-container">
            <div class="modal-header">
                <h3 id="modalDocTitle">Firmar Documento</h3>
                <button class="close-modal" onclick="DashboardApp.Modal.closeSignModal()">&times;</button>
            </div>
            <div class="modal-body">
                <div class="pdf-viewer-container">
                    <div class="pdf-placeholder"><i class="fa-solid fa-file-pdf fa-3x"></i><p>Vista previa del documento</p></div>
                </div>
                <div class="signature-panel">
                    <div class="signature-tabs">
                        <button class="tab-btn active" onclick="DashboardApp.Modal.switchSignTab('insertar')">Insertar Firma</button>
                        <button class="tab-btn" onclick="DashboardApp.Modal.switchSignTab('firmar')">Firmar</button>
                    </div>
                    <div id="tab-insertar" class="tab-content active">
                        <div class="signature-preview-container">
                            <p style="margin-bottom: 10px; color: #718ebf;">Firma registrada:</p>
                            <div class="signature-display"><img src="~/img/firma.png" alt="Firma" style="max-width: 100%; max-height: 80px;"></div>
                        </div>
                        <button class="btn-primary btn-sign-confirm" onclick="DashboardApp.Modal.closeSignModal()"><i class="fa-solid fa-pen-nib"></i> Insertar firma en documento</button>
                    </div>
                    <div id="tab-firmar" class="tab-content">
                        <p style="margin-bottom: 10px; color: #718ebf;">Dibuje su firma:</p>
                        <div class="signature-pad-container"><canvas id="signatureCanvas" width="300" height="150"></canvas></div>
                        <div class="pad-actions"><button class="btn-clear-sig" onclick="DashboardApp.Modal.clearCanvas()">Borrar</button></div>
                        <button class="btn-primary btn-sign-confirm" onclick="DashboardApp.Modal.closeSignModal()"><i class="fa-solid fa-check"></i> Guardar y Firmar</button>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- MODAL CREAR CARPETA -->
    <div id="createFolderModal" class="modal-overlay">
        <div class="modal-container" style="max-width: 400px; height: auto;">
            <div class="modal-header">
                <h3>Nueva Carpeta</h3>
                <button class="close-modal" onclick="DashboardApp.Folders.closeCreateModal()">&times;</button>
            </div>
            <div class="modal-body" style="padding: 20px; flex-direction: column; gap: 15px;">
                <div class="form-group">
                    <label style="display: block; margin-bottom: 8px; font-weight: 600; color: #343c6a;">Nombre de la carpeta</label>
                    <input type="text" id="newFolderName" class="form-input" placeholder="Ej: Contratos 2026" style="width: 100%;">
                </div>
                <div class="form-actions" style="display: flex; justify-content: flex-end; gap: 10px;">
                    <button class="btn-secondary" onclick="DashboardApp.Folders.closeCreateModal()">Cancelar</button>
                    <button class="btn-primary" onclick="DashboardApp.Folders.createFolder()">Crear</button>
                </div>
            </div>
        </div>
    </div>

    <!-- PANEL DE HISTORIAL -->
    <div id="historySidebar" class="history-sidebar">
        <div class="history-header">
            <h3>Historial del Documento</h3>
            <button class="close-history-btn" onclick="DashboardApp.HistoryPanel.close()">&times;</button>
        </div>
        <div class="history-body">
            <h4 id="historyDocTitle" style="margin-bottom: 20px; color: #151f6d;">Documento</h4>
            <ul class="timeline">
                <!-- Se llenará dinámicamente -->
            </ul>
        </div>
    </div>
    <div id="historyOverlay" class="history-overlay" onclick="DashboardApp.HistoryPanel.close()"></div>

    <!-- SweetAlert2 JS -->
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
@*     <script src="~/js/main.js"></script> *@
