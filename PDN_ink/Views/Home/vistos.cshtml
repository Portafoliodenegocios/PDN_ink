@using HR_Templates.Proxys

@model IEnumerable<Pdnink.Models.OriginacionModelTable>

@using Microsoft.Extensions.Configuration
@inject IConfiguration Configuration
@{
    ViewData["Title"] = "Home Page";
    Layout = "_Layout";
    string token = ViewData["TokenRH"] as string;
}
<div class="table-header-actions">
    <h2 class="table-title">Documentos Vistos</h2>
</div>

<!-- KPIs Detallados -->
<div class="dashboard-grid" style="margin-bottom: 30px;">
    <div class="kpi-container">
        <!-- Card 1: Vistos hoy -->
        <div class="kpi-card-detailed">
            <div class="kpi-card-title">Vistos hoy</div>
            <div class="kpi-stats-row">
                <div class="kpi-stat">
                    <span class="kpi-stat-value">8</span>
                    <span class="kpi-stat-label">Documentos</span>
                </div>
                <div class="kpi-stat">
                    <span class="kpi-stat-value">2</span>
                    <span class="kpi-stat-label">Usuarios</span>
                </div>
            </div>
        </div>

        <!-- Card 2: Vistos semana -->
        <div class="kpi-card-detailed">
            <div class="kpi-card-title">Vistos esta semana</div>
            <div class="kpi-stats-row">
                <div class="kpi-stat">
                    <span class="kpi-stat-value">45</span>
                    <span class="kpi-stat-label">Documentos</span>
                </div>
                <div class="kpi-stat">
                    <span class="kpi-stat-value">12</span>
                    <span class="kpi-stat-label">Usuarios</span>
                </div>
            </div>
        </div>

        <!-- Card 3: Más consultados -->
        <div class="kpi-card-detailed">
            <div class="kpi-card-title">Más consultados</div>
            <div class="kpi-stats-row">
                <div class="kpi-stat">
                    <span class="kpi-stat-value">Contratos</span>
                    <span class="kpi-stat-label">Tipo</span>
                </div>
                <div class="kpi-stat">
                    <span class="kpi-stat-value">28</span>
                    <span class="kpi-stat-label">Vistas</span>
                </div>
            </div>
        </div>

        <!-- Card 4: Tiempo promedio -->
        <div class="kpi-card-detailed">
            <div class="kpi-card-title">Tiempo promedio</div>
            <div class="kpi-stats-row">
                <div class="kpi-stat">
                    <span class="kpi-stat-value">5m</span>
                    <span class="kpi-stat-label">Lectura</span>
                </div>
                <div class="kpi-stat">
                    <span class="kpi-stat-value">98%</span>
                    <span class="kpi-stat-label">Completado</span>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Tabla Detallada -->
<div class="table-container">
    <table id="vistosTable">
        <thead>
            <tr>
                <th>Doc</th>
                <th class="filterable-header" data-col="1">
                    <div class="th-content"><span>Nombre del documento</span><i class="fa-solid fa-filter filter-icon"></i></div>
                    <div class="filter-dropdown"></div>
                </th>
                <th class="filterable-header" data-col="2">
                    <div class="th-content"><span>ID del documento</span><i class="fa-solid fa-filter filter-icon"></i></div>
                    <div class="filter-dropdown"></div>
                </th>
                <th class="filterable-header" data-col="3">
                    <div class="th-content"><span>Creador</span><i class="fa-solid fa-filter filter-icon"></i></div>
                    <div class="filter-dropdown"></div>
                </th>
                <th class="filterable-header" data-col="4">
                    <div class="th-content"><span>Propietario</span><i class="fa-solid fa-filter filter-icon"></i></div>
                    <div class="filter-dropdown"></div>
                </th>
                <th>Participantes</th>
                <th>Creado</th>
                <th class="filterable-header" data-col="7">
                    <div class="th-content"><span>Estatus</span><i class="fa-solid fa-filter filter-icon"></i></div>
                    <div class="filter-dropdown"></div>
                </th>
                <th>Día</th>
                <th>Firma</th>
                <th><i class="fa-solid fa-gear" style="color: #718ebf;"></i></th>
            </tr>
        </thead>
        <tbody>
            <tr>
                <td>
                    <button class="doc-btn" onclick="DashboardApp.Modal.openSignModal('Contrato Marco')">
                        <img src="~/img/pdf.jpg" alt="PDF">
                    </button>
                </td>
                <td><div class="cell-wrap">RFC-CONSTANCIA-COMERCIALIZADORA DE PRODUCTOS PARA LA INVESTIGACION Y LA SALUD, S.A. DE C.V.-062024-26782.pdf</div></td>
                <td><div class="cell-truncate">DOC-2026-010</div></td>
                <td>Evelin Ramirez</td>
                <td>Juan Perez</td>
                <td>
                    <div class="participant-list">
                        <span class="participant-badge badge-blue">Lucia Castellanos</span>
                        <span class="participant-badge badge-teal">Cesar Dorantes</span>
                    </div>
                </td>
                <td>02/02/2026</td>
                <td>
                    <div class="status-wrapper">
                        <span class="status-dot status-green"></span> Visto
                    </div>
                </td>
                <td>-</td> <!-- Se calcula con JS -->
                <td><i class="fa-solid fa-pen-nib" style="color: #718ebf;"></i></td>
                <td>
                    <div class="action-menu-container">
                        <button class="table-action-btn" title="Acciones">
                            <i class="fa-solid fa-bars"></i>
                        </button>
                        <div class="action-dropdown">
                            <a href="#"><i class="fa-solid fa-pen"></i> Editar</a>
                            <a href="#"><i class="fa-solid fa-check"></i> Finalizar</a>
                            <a href="#"><i class="fa-solid fa-box-archive"></i> Archivar</a>
                            <a href="#"><i class="fa-solid fa-copy"></i> Duplicar</a>
                            <div class="divider"></div>
                            <a href="#"><i class="fa-solid fa-file-pdf"></i> Descargar PDF</a>
                            <a href="#"><i class="fa-solid fa-eye"></i> Ver Documento</a>
                            <div class="divider"></div>
                            <a href="#" class="danger"><i class="fa-solid fa-trash"></i> Eliminar</a>
                        </div>
                    </div>
                </td>
            </tr>
            <tr>
                <td>
                    <button class="doc-btn" onclick="DashboardApp.Modal.openSignModal('Manual de Operaciones')">
                        <img src="/img/pdf.jpg" alt="PDF">
                    </button>
                </td>
                <td><div class="cell-wrap">Manual de Operaciones 2026</div></td>
                <td><div class="cell-truncate">DOC-2026-015</div></td>
                <td>Carlos Ruiz</td>
                <td>Maria Garcia</td>
                <td>
                    <div class="participant-list">
                        <span class="participant-badge badge-purple">Pedro Lopez</span>
                    </div>
                </td>
                <td>20/01/2026</td>
                <td>
                    <div class="status-wrapper">
                        <span class="status-dot status-green"></span> Visto
                    </div>
                </td>
                <td>-</td> <!-- Se calcula con JS -->
                <td><i class="fa-solid fa-pen-nib" style="color: #718ebf;"></i></td>
                <td>
                    <div class="action-menu-container">
                        <button class="table-action-btn" title="Acciones">
                            <i class="fa-solid fa-bars"></i>
                        </button>
                        <div class="action-dropdown">
                            <a href="#"><i class="fa-solid fa-pen"></i> Editar</a>
                            <a href="#"><i class="fa-solid fa-check"></i> Finalizar</a>
                            <a href="#"><i class="fa-solid fa-box-archive"></i> Archivar</a>
                            <a href="#"><i class="fa-solid fa-copy"></i> Duplicar</a>
                            <div class="divider"></div>
                            <a href="#"><i class="fa-solid fa-file-pdf"></i> Descargar PDF</a>
                            <a href="#"><i class="fa-solid fa-eye"></i> Ver Documento</a>
                            <div class="divider"></div>
                            <a href="#" class="danger"><i class="fa-solid fa-trash"></i> Eliminar</a>
                        </div>
                    </div>
                </td>
            </tr>
        </tbody>
    </table>
</div>