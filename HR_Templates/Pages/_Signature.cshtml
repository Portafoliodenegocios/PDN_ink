@page
@model SignatureModel
@{
    Layout = null;
}

@Html.AntiForgeryToken()

<style>
    .signature-container {
        max-width: 520px;
        margin: auto;
        padding: 25px;
        border-radius: 14px;
        background: #ffffff;
        box-shadow: 0 15px 40px rgba(0,0,0,0.15);
        text-align: center;
    }

    .signature-title {
        font-size: 20px;
        font-weight: 600;
        margin-bottom: 15px;
        color: #222;
    }

    canvas {
        width: 100%;
        height: 200px;
        border: 2px solid #bdbdbd; /* 🔥 más visible */
        border-radius: 10px;
        background: #ffffff;
        display: block;
    }

    .signature-hint {
        font-size: 13px;
        color: #666;
        margin-top: 10px;
    }

    .actions {
        display: flex;
        justify-content: space-between;
        margin-top: 20px;
        gap: 15px;
    }

    .btn-custom {
        flex: 1;
        border-radius: 10px;
        padding: 12px;
        font-weight: 600;
        font-size: 14px;
        transition: all 0.2s ease;
        border: none;
    }

    .btn-clear {
        background: #f44336;
        color: white;
    }

        .btn-clear:hover {
            background: #c62828;
        }

    .btn-save {
        background: #43a047;
        color: white;
    }

        .btn-save:hover {
            background: #2e7d32;
        }
</style>
<div class="signature-container">

    @* <div class="signature-title">
        ✍ Firma del documento
    </div> *@

    <canvas id="Lienzo"></canvas>

    <div class="signature-hint">
        Usa el mouse o tu dedo para firmar
    </div>

    <div class="actions">
        <button type="button" onclick="clearPad()" class="btn btn-custom btn-clear">
            Limpiar
        </button>

        <button type="button" onclick="saveSignature()" class="btn btn-custom btn-save">
            Enviar Firma
        </button>
    </div>

</div>

<input type="hidden" id="documentName" value="@Model.DocumentName" />