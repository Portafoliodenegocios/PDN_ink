@page "/Spreadsheet"
@model HR_Templates.Pages.SpreadsheetModel
@using DevExpress.AspNetCore;
@inject Microsoft.AspNetCore.Hosting.IWebHostEnvironment env
@inject Microsoft.AspNetCore.Antiforgery.IAntiforgery Antiforgery
@using DevExpress.Spreadsheet
@using Microsoft.AspNetCore.Http.Features
@using System.IO
@{
    var documentPath = string.Empty;
    if (@ViewData["NameTemplate"] != null)
    {
      documentPath = System.IO.Path.Combine(
                              env.ContentRootPath,
                              DirectoryManagmentUtils.GetDocumentSampleFolderPath(HttpContext), 
                              @ViewData["NameTemplate"].ToString());
    }

}


