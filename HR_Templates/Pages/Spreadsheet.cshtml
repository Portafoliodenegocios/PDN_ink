 @* Control Spreedsheet *@
@(
Html.DevExpress()
    .Spreadsheet("spreadsheet")
    .Width("100%")
    .Height("800px")
    .Ribbon(ribbon => ribbon
         .Visible(true)        
         .Tabs(tabs => {
               tabs.Clear();
               tabs.Add()
                   .Title("✍️")
                   .Items(items => {
                          items.AddButton()
                               .Text("Firmar documento")
                               .CommandName("FirmarDocumento")
                               .ShowText(true)
                               .Icon("edit");
                          items.AddPrintItem().BeginGroup(true);  
                   });
         })
         )
    .ClientSideEvents(events => {
                       events.OnCustomCommandExecuted("onCustomCommandExecuted");
                       events.OnBeforeSend("spreadsheet_beforeSend");
                       events.OnCellBeginEdit("onCellBeginEdit");
                       events.OnCellEndEdit("onCellEndEdit");
                   })
    .ConfirmOnLosingChanges(confirm => confirm.Enabled(false))
    .DocumentRequestHandlerUrl("Spreadsheet?handler=DxSpreadsheetRequest")               
    .Open(documentPath)
)
 
         



