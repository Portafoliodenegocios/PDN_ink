@page "/Spreadsheet"
@model HR_Templates.Pages.SpreadsheetModel
@using DevExpress.AspNetCore;
@inject Microsoft.AspNetCore.Hosting.IWebHostEnvironment env
@inject Microsoft.AspNetCore.Antiforgery.IAntiforgery Antiforgery
@using DevExpress.Spreadsheet
@using Microsoft.AspNetCore.Http.Features
@using System.IO

 @{
    var documentPath = string.Empty;
     var NameFileout = string.Empty;
    var context_ = HttpContext;

    if (@ViewData["NameTemplate"] != null)
    {

        const string Z = "NameTemplate";
        string NameFilext = @ViewData[Z].ToString();

        documentPath = System.IO.Path.Combine(
                                env.ContentRootPath,
                                DirectoryManagmentUtils.GetDocumentSampleFolderPath(HttpContext), 
                                NameFilext
                                );


    }

    if (@ViewData["NameFile"] != null)
    {
        const string V = "NameFile";
        NameFileout = @ViewData[V]?.ToString();
    }

}
<script>

    window.APP_CONFIG = 
          {
                documentName: @Html.Raw(Json.Serialize(NameFileout)),
                token: "@Antiforgery.GetAndStoreTokens(HttpContext).RequestToken"
         };
 </script>
   
