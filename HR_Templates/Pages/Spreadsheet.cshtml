 events.OnCustomCommandExecuted("onCustomCommandExecuted");
         })
         @* .ConfirmOnLosingChanges(confirm => confirm.Enabled(false))
            
            .DocumentRequestHandlerUrl(Url.Action("DxDocumentRequest"))  *@
         
.Open(documentPath)
        )
 
         
<script type="text/javascript">
        

   
       
   
        
    function OpenModalSign()
    {
    document.getElementById("signatureModal").style.display = "flex";
    }
    function CloseModalSign()
    {
    const modalEl = document.getElementById('signatureModal');
    const modal = bootstrap.Modal.getInstance(modalEl);
    if (modal) modal.hide();
    // document.getElementById("signatureModal").style.display = "none";
    }

       
     
    function initSignaturePad() {

    const canvas = document.getElementById('Lienzo');
    if (!canvas) return;

    const ctx = canvas.getContext('2d');
    let drawing = false;

    canvas.addEventListener('mousedown', e =>
    {
    drawing = true;
    ctx.beginPath();
    ctx.moveTo(e.offsetX, e.offsetY);
    });

    canvas.addEventListener('mousemove', e =>
    {
    if (!drawing) return;
    ctx.lineTo(e.offsetX, e.offsetY);
    ctx.stroke();
    });

    canvas.addEventListener('mouseup', () => drawing = false);
    canvas.addEventListener('mouseleave', () => drawing = false);

    window.clearPad = function () {
    ctx.clearRect(0, 0, canvas.width, canvas.height);
    };

    window.saveSignature = function ()
    {

    const canvas = document.getElementById("Lienzo");
    const imageData = canvas.toDataURL("image/png");
    const token = document.querySelector('input[name="__RequestVerificationToken"]').value;
    const documentName = document.getElementById("documentName").value;

    fetch("/Spreadsheet?handler=SaveSignature", {
    method: "POST",
    headers: {
    "Content-Type": "application/json",
    "RequestVerificationToken": token
    },
    body: JSON.stringify({
    imageData: imageData,
    documentName: documentName
    })
    })
    .then(async res => {
    if (!res.ok) {
    const text = await res.text();
    console.error("Error servidor:", text);
    throw new Error("Error en request");
    }

    return res.json();
    })
    .then(data => {
    if (data.success) {
         Guardar();
    alert('Documento enviado correctamente!!');
    CloseModalSign();
    } else {
    alert('Error');
    }
    })
    .catch(err => {
    console.error(err);
    alert("Falló el guardado");
    });
    };
                                       

    }

    async function openSignaturePopup(documentName)
    {
                                   
    const url = '_Signature?documentName=' + encodeURIComponent(documentName);
    alert(url);
     alert('qui entro');
    const response = await fetch(url);
    const html = await response.text();

    document.getElementById("signatureContainer").innerHTML = html;

    var modal = new bootstrap.Modal(document.getElementById('signatureModal'));
    modal.show();

    setTimeout(() => {
    initSignaturePad();
    }, 200);
    }


      
</script>


   
   
   



