 <script> 
    function onCustomCommandExecuted(s, e) {
    console.log("Comando:", e.commandName);
    switch (e.commandName) {
    case 'save':
      openSignaturePopup('Documento1')
        // Guardar();  
        break;
    case 'download':
    var spreadsheetState = spreadsheet.getSpreadsheetState();
    $("#formExport").attr('action', '@Url.Action("RibbonDownloadXlsx")');
    $("input[name='SpreadsheetWorkSessionId']").val(spreadsheetState.SpreadsheetWorkSessionId);
    $("#formExport").submit();
    break;
    }
    }

    function Guardar()
    {
      var spreadsheet = ASPxClientControl.GetControlCollection().GetByName("spreadsheet");
      var spreadsheetState = spreadsheet.GetSpreadsheetState();
    
        console.log(spreadsheetState);
        console.log('save_');
    fetch('/Spreadsheet?handler=RibbonSaveToFile', {
        method: 'POST',
        headers: {
            'Content-Type': 'application/json'
        },
        body: JSON.stringify({ spreadsheetState: spreadsheetState })
    })
    .then(res => console.log("Guardado OK"))
    .catch(err => console.error(err));
    }
</script>
 
@(
Html.DevExpress()
    .Spreadsheet("spreadsheet")
    .Width("100%")
