@page
@model HR_Templates.Pages.VisorReportModel
@Html.AntiForgeryToken()
@inject Microsoft.AspNetCore.Hosting.IWebHostEnvironment env
@{
    var Namerpt = string.Empty;
    var Fullname = string.Empty;
    var Position = string.Empty;
    var EmployeeId = string.Empty;
    var Area = string.Empty;
    var Tkn_ = string.Empty;
    var context_ = HttpContext;
    Layout = null;      

    if (@ViewData["NameReport"] != null)
    {
        const string V = "NameReport";
        Namerpt = @ViewData[V]?.ToString();
        Fullname = @ViewData["FullName"]?.ToString();
        Position = @ViewData["Position"]?.ToString();
        EmployeeId = @ViewData["EmployeeId"]?.ToString();
        Area = @ViewData["Area"]?.ToString();
        Tkn_ = @ViewData["Token_"]?.ToString();
    }
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <title>Visor de Reporte</title>
    <link href="~/hr/css/Sign.css" rel="stylesheet" type="text/css" runat="server" />
    <link href="~/hr/css/VisorReport.css" rel="stylesheet" type="text/css" runat="server" />
    <script src="~/hr/js/signature.js"></script>
    <script src="~/hr/js/api.js"></script>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
</head>
<body>
    @* <input type="hidden" asp-for="rptDocumentName" value="@ViewData["rptDocumentName"].ToString()" /> *@
    @*    <input type="hidden" asp-for="RptUserName" />*@
      <!-- HEADER -->
    <div class="viewer-header">

        <div class="viewer-title">
            📄 Visor ©️Pdn
        </div>

        <div class="viewer-actions">
            <button id="btnFirmar" onclick="OpenModalSign(); return false;" class="btn btn-primary">
                ✍ Firmar Documento
            </button>        
        </div>

    </div>
    <!-- VISOR PDF -->
    <iframe id="pdfViewer" class="viewer-frame">
    </iframe>

    <!-- MODAL FIRMA -->
    <div id="modalSign" class="modal-overlay">
        <div class="modal-box">
            <canvas id="Lienzo"
                    width="420"
                    height="200"
                    class="canvas-signature"></canvas>
            <div class="modal-buttons">
                <button type="button" onclick="clearPad()" class="btn-danger">
                    🧹 Limpiar
                </button>
                <button type="button" onclick="saveSignature()" class="btn-success">
                    ✔  Firma
                </button>
                <button type="button" onclick="CloseModalSign()" class="btn-secondary">
                    ❎ Cancelar
                </button>
            </div>
