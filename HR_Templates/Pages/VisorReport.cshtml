        // --- SECCIÓN: DATOS GENERALES ---
        if (!get("rpNombre_Empleado")?.value.trim())
        mensajes.push("• Nombre del empleado requerido");

        if (!get("rpLugar")?.value.trim())
        mensajes.push("• Lugar requerido");

        if (!get("rp_Fecha")?.value)
        mensajes.push("• Fecha requerida");

        // --- VALIDACIÓN FINAL ---
        if (mensajes.length > 0) {
        Swal.fire({
        icon: "warning",
        title: "Faltan datos Aviso de Privacidad",
        html: mensajes.join("<br>"),
        confirmButtonText: "OK"
        });
        return false;
        }

        return true;
