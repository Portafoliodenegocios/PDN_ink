    <script>


        var Fullname = '@Fullname';
        var Reportname ='@Namerpt';
        var Position ='@Position';
        var EmployeeId ='@EmployeeId';
        var Area ='@Area';
        var T_o_k_e_n ='@Tkn_';
        const NameFile_ = @Html.Raw(Json.Serialize(Namerpt));
        const FullName_ = @Html.Raw(Json.Serialize(Fullname));
        
        document.addEventListener("DOMContentLoaded", function () 
        {

    
        const normalizeFormFields = (formId) => {

            const form = document.getElementById(formId);
            if (!form) return;

            form.querySelectorAll("input, textarea, select")
                .forEach(el => {

            if (!el.name && el.id) {

            el.name = el.id
            .normalize("NFD")
            .replace(/[\u0300-\u036f]/g, "");
            }
            });
        };
        normalizeFormFields("formCertificate");
        
        const reportActions = 
        {        
            rptCertificateReturnVehicles: () =>   openModal("modalCertificate"),                                // Acta de entrega y devolución de vehículos
            rptBonusAuthorization: () =>  openModal("modalBono"),                                               // Autorización de pago de bono
            rptPrivacyNotice: () =>   openModal("modalPrivacyNotice"),                                          // Aviso de privacidad      
            rptJobPositionChange: () => openModal("modalPositionChange"),                                       // Cambio de puesto o área del personal
            rptInfonavitNoDebtLetter: () => openModal("modalNoDebtInfonavit"),                                  // Carta no adeudo infonavit
            rptTerminationletter: () => openModal("modalSettlementLetter"),                                     // Carta finiquito
            rptInstructionletter: () => openModal("modalInstructionLetter"),                                    // Carta instrucción
            rptAcceptanceScholarship: () => submitReportservices(),                                             // Aceptación reglamento becarios
            rtpLetterofAcceptanceoftheCodeofEthicsandConduct: () => submitReportservices(),                     // Código ética y conducta
            rptLetterofAcceptanceofScholarshipPaymentIntoBankAccount: () =>   submitReportservices(),           // Carta aceptación beca bancaria
            rptLetterAcceptanceRegulations: () =>  submitReportservices(),                                      // Reglamento interno trabajo
            rptVehicleresponsibilityletterdesignating: () =>  openModal("modalVehicleResponsibilityLetter"),    // Carta responsiva vehículo
            rtpIndividualScholarshipAgreement: () =>     openModal("modalScholarshipAgreement"),                // Convenio individual beca
            rptIntellectualPropertyRights: () =>      openModal("modalIntellectualPropertyRights"),             // Derechos intelectuales
            rtpDataBaseChangeRequestForm: () =>     openModal("modalDatabaseChangeRequest"),                    // Solicitud cambios BD
            rtpRequirementsRequestForm: () =>      openModal("modalSoftwareDevelopmentRequest") ,               // Solicitud desarrollo software
            rtpNotificationofPenaltyforDelay: () =>      openModal("modalDelayNotification"),                   // Notificacion de sancion por retardo
            rptVehicleFaultReport: () =>      openModal("modalVehicleFailureReport"),                           // Reporte de fallas de vehículos
            rptCollectionBoardReport: () =>      openModal("modalCollectionMeetingReport"),                     // Reporte de junta de cobranza
            rptPersonalLoanApplication: () =>      openModal("modalTemporaryLoanRequest")                       // Solicitud de préstamo temporal
        };               
       
        reportActions[NameFile_]?.();

        });

        function openModal(modalId)
        {
        const modalElement = document.getElementById(modalId);

        if (!modalElement) return;

        // const modal = new bootstrap.Modal(modalElement);

        const modal = new bootstrap.Modal(modalElement, {
        backdrop: 'static',
        keyboard: false
        });

        // Modales que requieren enviar datos para la ejecución
        const fillableModals = new Set([
                "modalCertificate",
                "modalBono",
                "modalPrivacyNotice",
                "modalNoDebtInfonavit",
                "modalPositionChange",
                "modalSettlementLetter",
                "modalInstructionLetter",
                "modalVehicleResponsibilityLetter",
                "modalScholarshipAgreement",
                "modalIntellectualPropertyRights",
                "modalDatabaseChangeRequest",
                "modalSoftwareDevelopmentRequest",
                "modalDelayNotification",
                "modalVehicleFailureReport",
                "modalCollectionMeetingReport",
                "modalTemporaryLoanRequest"
        ]);

        // Reportes automáticos
        const autoSubmitReports = new Set([
                "rptAcceptanceScholarship",
                "rtpLetterofAcceptanceoftheCodeofEthicsandConduct",
                "rptLetterofAcceptanceofScholarshipPaymentIntoBankAccount",
                "rptLetterAcceptanceRegulations"
        ]);

        // Ejecutar acciones
        if (fillableModals.has(modalId))
        {
           fillFormdata(modalId);
           modal.show();
           return;
        }

        if (autoSubmitReports.has(modalId))
        {
           submitReportservices();
           return;
        }
       
        modal.show();
        }
          
        function fillFormdata(namemodal)
        {

        const fechaActual = getFechaActual();
             
        const commonValues = { fechaActual, Fullname, Position, EmployeeId, Area, Reportname };
              
        const setValue = (id, value) => {
        const element = document.getElementById(id);

        if (element && value !== undefined && value !== null)
            element.value = value;
        };

        // Configuración por modal
        const modalConfig = {

        
        modalCertificate: {  // Acta de entrega y devolución de vehículos
            rpFechaDocumento: commonValues.fechaActual,   rpFechaEntrega: commonValues.fechaActual,    rpFechaDevolucion: commonValues.fechaActual,       
            rpNombreColaborador: commonValues.Fullname,   rpPuestoColaborador: commonValues.Position,  rpNEmpleado: commonValues.EmployeeId,
            rpArea: commonValues.Area,                    ReportName: commonValues.Reportname   },        
        modalBono: { // Autorización de pago de bono
            rpFecha: commonValues.fechaActual,            rpNombreEmpleado: commonValues.Fullname,     rpPuesto: commonValues.Position,   
            rpNEmpleadob: commonValues.EmployeeId,        rpAreab: commonValues.Area,                  rpPrimerFecha: commonValues.fechaActual,           
            rpSegundaFecham: commonValues.fechaActual,    ReportName: commonValues.Reportname   },        
        modalPrivacyNotice: { // Aviso de privacidad
            rp_Fecha: commonValues.fechaActual,           rpNombre_Empleado: commonValues.Fullname      },        
        modalPositionChange: { // Cambio de puesto o área del personal
            rpFechaCambio: commonValues.fechaActual,      rpFechaIngreso: commonValues.fechaActual,    rpNombre: commonValues.Fullname   },        
        modalNoDebtInfonavit: { // No adeudo Infonavit
            rpFecha_: commonValues.fechaActual,           rpNombre_: commonValues.Fullname      },        
        modalSettlementLetter: { // Carta finiquito
            rpFechaf: commonValues.fechaActual,           rpNombref: commonValues.Fullname,            rpNumero: commonValues.EmployeeId,
            rpFechaFinal: commonValues.fechaActual                                              },        
        modalInstructionLetter: { // Carta instrucción
            rpFechai: commonValues.fechaActual,           rpFechaPagare: commonValues.fechaActual,    rpNombres: commonValues.Fullname   },       
        modalVehicleResponsibilityLetter: {  // Carta responsiva vehículo
            rpFechar: commonValues.fechaActual,           rpNombrer: commonValues.Fullname      },        
        modalScholarshipAgreement: { // Convenio individual de beca
            rpFechaIt: commonValues.fechaActual,          rpFechaTt: commonValues.fechaActual,        rpNombret: commonValues.Fullname   },        
        modalIntellectualPropertyRights: { // Derechos intelectuales
            rpFechaDocumentoi: commonValues.fechaActual,  rpArej: commonValues.Area,                  rpPuestoi: commonValues.Position,
            rpNombreColaboradori: commonValues.Fullname                                         },        
        modalDatabaseChangeRequest: {  // Solicitud cambios BD
            rpFechadb: commonValues.fechaActual,          rpNSolicitante: commonValues.Fullname,      rpNDR: commonValues.Fullname       },        
        modalSoftwareDevelopmentRequest: {  // Solicitud desarrollo software
            rpFechasw: commonValues.fechaActual,          rpNombresw: commonValues.Fullname,          rpAreasw: commonValues.Area       },
        modalDelayNotification: {  // Notificacion de sancion por retardo
            rpFechant: commonValues.fechaActual,         rpFechaHoy:commonValues.fechaActual,        rpSancion:commonValues.fechaActual,
            rpNombrent: commonValues.Fullname,           rpPuestont:commonValues.Position,           rpDepartamentont: commonValues.Area },
        modalVehicleFailureReport:  {  // Reporte de fallas de vehículos
            rpFechavh: commonValues.fechaActual,         rpNombrevh: commonValues.Fullname },
        modalCollectionMeetingReport: { // Reporte de junta de cobranza
           rpFechaCarteraVencida: commonValues.fechaActual },
        modalTemporaryLoanRequest: { // Solicitud de préstamo temporal 
           rpFechapt: commonValues.fechaActual,          rpNombrept: commonValues.Fullname,           rpNomina: commonValues.EmployeeId,  
           rpFechaIpt: commonValues.fechaActual,         rpAreapt: commonValues.Area,                 rpFechaUpt : commonValues.fechaActual }                                                                                  
        };

        // Obtener configuración
        const fields = modalConfig[namemodal];

        if (!fields) return;

        // Asignar valores
        Object.entries(fields).forEach(([id, value]) => {
        setValue(id, value);
        });
        }

        function closeModal(modalId) {

        const modalElement = document.getElementById(modalId);
        const modalInstance = bootstrap.Modal.getInstance(modalElement);

        if (modalInstance) {
        modalInstance.hide();
        }

        setTimeout(() => {
        if (window.history.length > 1) {
        window.history.back();
        } else {
        window.location.href = '/Formatos';
        }
        }, 300);

        }

        function submitReportservices() {

        Swal.fire({
        title: "Generando reporte...",
        allowOutsideClick: false,
        didOpen: () => Swal.showLoading()
        });
        debugger;
        const formData = new FormData();

        debugger;

        formData.append("Reportname", Reportname);
        formData.append("Fullname", Fullname);
        debugger;

        fetch('/VisorReport?handler=GenerateReport', {
        method: 'POST',
        headers: {
          "Authorization": `Bearer ${T_o_k_e_n}`,
          "RequestVerificationToken": document.querySelector('input[name="__RequestVerificationToken"]').value
        },
        body: formData
        })
        .then(res => res.json())
        .then(data => {

        Swal.close();

        if (!data.success) {
        Swal.fire("Error", "No se pudo generar reporte", "error");
        return;
        }

        document.getElementById("pdfViewer").src =
        "/pdfjs/web/viewer.html?file=" + encodeURIComponent(data.url);

        })
        .catch(err => {
        Swal.close();
        Swal.fire("Error", err.toString(), "error");
        });
        }

        async function  submitReportData(modalId, formId) {

        const reportConfig = {

        modalCertificate: { validate: validateFormCertificate, url: "/VisorReport?handler=GenerateVehicleReport"   },                   // Acta de entrega y devolución de vehículos
        modalBono: { validate: validateFormBono, url: "/VisorReport?handler=GenerateBonoReport"   },                                    // Autorización de pago de bono
        modalPrivacyNotice: { validate: validatePrivacyNoticeForm, url: "/VisorReport?handler=GeneratePrivacyNoticedReport" },          // Aviso de privacidad
        modalPositionChange: {validate: validatePositionChangeForm, url: "/VisorReport?handler=GeneratePositionChangeReport"},          // Cambio de puesto o área del personal
        modalNoDebtInfonavit: {validate: validateNoDebtInfonavitForm, url: "/VisorReport?handler=GenerateNoDebtInfonavitReport"},       // No adeudo Infonavit
        modalSettlementLetter: {validate: validateSettlementLetterForm, url: "/VisorReport?handler=GenerateSettlementLetterReport"},    // Carta finiquito
        modalInstructionLetter: {validate: validateInstructionLetterForm,url: "/VisorReport?handler=GenerateInstructionLetterReport"},  // Carta instrucción
        modalScholarshipAgreement: {validate: validateScholarshipAgreementForm,url: "/VisorReport?handler=GenerateScholarshipAgreementReport"}, // Convenio individual de beca
        modalIntellectualPropertyRights: { validate: validateIntellectualPropertyRightsForm, url: "/VisorReport?handler=GenerateIntellectualPropertyRightsReport"},  // Derechos intelectuales
        modalVehicleResponsibilityLetter: { validate: validateVehicleResponsibilityLetterForm, url: "/VisorReport?handler=GenerateVehicleResponsibilityLetterReport"},// Carta responsiva vehículo
        modalDatabaseChangeRequest: { validate: validateDatabaseChangeRequestForm, url: "/VisorReport?handler=GenerateDatabaseChangeRequestReport" }, // Solicitud cambios BD
        modalSoftwareDevelopmentRequest: { validate: validateSoftwareDevelopmentRequestForm, url: "/VisorReport?handler=GenerateSoftwareDevelopmentRequestReport"}, // Solicitud desarrollo software
        modalDelayNotification: { validate: validateDelayNotificationForm, url: "/VisorReport?handler=GenerateDelayNotificationReport"}, //Notificacion de sancion por retardo
        modalVehicleFailureReport: { validate: validateVehicleFailureReportForm, url: "/VisorReport?handler=GenerateVehicleFailureReport"}, //Reporte de fallas de vehículos
        modalCollectionMeetingReport: { validate: validateCollectionMeetingReportForm, url: "/VisorReport?handler=GenerateCollectionMeetingReport"}, // Reporte de junta de cobranza
        modalTemporaryLoanRequest: { validate: validateTemporaryLoanRequestForm, url: "/VisorReport?handler=GenerateTemporaryLoanRequestReport"},    // Solicitud de préstamo temporal
        };
        
        const config = reportConfig[modalId];

        if (!config) {
        console.error("Configuración no encontrada para:", modalId);
        return;
        }

        if (!config.validate(formId))
        return;

        const modal = document.getElementById(modalId);
        const form = document.getElementById(formId);

        if (!form)
        {
        console.error("Formulario no encontrado");
        return;
        }

        Swal.fire({
        title: "Espere un momento por favor",
        allowOutsideClick: false,
        didOpen: () => Swal.showLoading()
        });

        try
        {
        const formData = new FormData(form);

        const response = await fetch(config.url, {
        method: "POST",
        headers: {
        "Authorization": `Bearer ${T_o_k_e_n}`,
        "RequestVerificationToken": document.querySelector('input[name="__RequestVerificationToken"]').value
        },
        
        body: formData
        });

        const data = await response.json();

        Swal.close();

        if (!data.success)
        {
        Swal.fire({
        icon: "error",
        title: "Error",
        text: "No fue posible generar el reporte"
        });

        return;
        }

        // Mostrar PDF
        document.getElementById("pdfViewer").src =
        "/pdfjs/web/viewer.html?file=" + encodeURIComponent(data.url);

        // Cerrar modal
        bootstrap.Modal
        .getInstance(modal)
        ?.hide();
        }
        catch (err)
        {
        Swal.close();

        Swal.fire({
        icon: "error",
        title: "Error",
        text: err.message || err
        });

        console.error(err);
        }

       
        }
              
        function getFechaActual(includeTime = false)
        {
        const now = new Date();

        const year = now.getFullYear();
        const month = String(now.getMonth() + 1).padStart(2, '0');
        const day = String(now.getDate()).padStart(2, '0');

        // Para input type="date"
        if (!includeTime)
        {
        return `${year}-${month}-${day}`;
        }

        // Para input type="datetime-local"
        const hours = String(now.getHours()).padStart(2, '0');
        const minutes = String(now.getMinutes()).padStart(2, '0');

        return `${year}-${month}-${day}T${hours}:${minutes}`;
        }
   
        function validateFormCertificate(formId) {

        const get = id => document.getElementById(id);
        let mensajes = [];

               

        if (!get("rpNombreColaborador")?.value.trim())
        mensajes.push("• Nombre requerido");

        if (!get("rpPuestoColaborador")?.value.trim())
        mensajes.push("• Puesto requerido");

        if (!get("rpNEmpleado")?.value.trim())
        mensajes.push("• Número de empleado requerido");

        if (!get("rpArea")?.value.trim())
        mensajes.push("• Área requerida");

       
        const entrega = get("rpentrega")?.checked;
        const devolucion = get("rpDevolucion")?.checked;

        if (!entrega && !devolucion)
        mensajes.push("• Selecciona Entrega o Devolución");

        
        if (!get("rpFechaEntrega")?.value)
        mensajes.push("• Fecha de entrega requerida");

        if (!get("rpFechaDevolucion")?.value)
        mensajes.push("• Fecha de devolución requerida");

        const docs = [
        get("rpPolizaSeguro")?.checked,
        get("rpTarjetaCirculacion")?.checked,
        get("rpVerificacion")?.checked,
        get("rpManual")?.checked
        ];

        if (!docs.some(d => d))
        mensajes.push("• Selecciona al menos un documento");

        if (!get("rpMarcaTipo")?.value.trim())
        mensajes.push("• Marca requerida");

        if (!get("rpPlacas")?.value.trim())
        mensajes.push("• Placas requeridas");

        if (!get("rpModelo")?.value.trim())
        mensajes.push("• Modelo requerido");

        if (!get("rpKilometrajeInicial")?.value.trim())
        mensajes.push("• Km inicial requerido");

       

        if (!get("rpNombreEntrega")?.value.trim())
        mensajes.push("• Nombre quien entrega requerido");

       

     
        if (mensajes.length > 0) {
        Swal.fire({
        icon: "warning",
        title: "Faltan datos",
        html: mensajes.join("<br>"),
        confirmButtonText: "Entendido"
        });
        return false;
        }

        return true;
        }
               
        function validateFormBono(formId) 
        {

        const get = id => document.getElementById(id);
        let mensajes = [];

        // --- SECCIÓN: DATOS DEL EMPLEADO ---
        if (!get("rpFecha")?.value)
        mensajes.push("• Fecha requerida");

        if (!get("rpNombreEmpleado")?.value.trim())
        mensajes.push("• Nombre del empleado requerido");

        if (!get("rpPuesto")?.value.trim())
        mensajes.push("• Puesto requerido");

        if (!get("rpNEmpleadob")?.value.trim())
        mensajes.push("• Número de empleado requerido");

        if (!get("rpAreab")?.value.trim())
        mensajes.push("• Área requerida");

        // --- SECCIÓN: INFORMACIÓN DEL BONO ---
        if (!get("rpMotivoBono")?.value.trim())
        mensajes.push("• Motivo del bono requerido");

        const monto = get("rpMontoBono")?.value;
        if (!monto || parseFloat(monto) <= 0)
        mensajes.push("• Monto del bono debe ser mayor a 0");

        if (!get("rpPrimerFecha")?.value)
        mensajes.push("• Primer mes (fecha) requerido");

        if (!get("rpSegundaFecham")?.value)
        mensajes.push("• Segunda fecha requerida");

        if (!get("rpNQuincenas")?.value.trim())
        mensajes.push("• Número de quincenas requerido");

        if (!get("rpNMeses")?.value.trim())
        mensajes.push("• Número de meses requerido");

        if (!get("rpObservaciones")?.value.trim())
        mensajes.push("• Observaciones requerido");

        // --- VALIDACIÓN FINAL ---
        if (mensajes.length > 0) {
        Swal.fire({
        icon: "warning",
        title: "Faltan datos del Bono",
        html: mensajes.join("<br>"),
        confirmButtonText: "Entendido"
        });
        return false;
        }

        return true;
        }

